<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla PTT — Material Design 3 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ── Barra superior: estado + sesión ───────────────────────────────────── -->

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="@string/status_idle"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSessionId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="monospace"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Peer status ────────────────────────────────────────────────────────── -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPeerStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="?attr/colorTertiaryContainer"
        app:cardElevation="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvSessionId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPeerStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text=""
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnTertiaryContainer" />

    </com.google.android.material.card.MaterialCardView>

    <!-- ── Métricas ────────────────────────────────────────────────────────────── -->

    <TextView
        android:id="@+id/tvMetrics"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:text=""
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="monospace"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardPeerStatus"
        app:layout_constraintBottom_toTopOf="@id/btnPtt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.8" />

    <!-- ── Botón PTT (grande, centrado verticalmente) ─────────────────────────── -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPtt"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:text="@string/ptt_press"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/colorOnPrimary"
        android:enabled="false"
        app:cornerRadius="110dp"
        app:backgroundTint="@color/ptt_idle"
        app:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.52" />

    <!-- ── Botones de acción inferiores ──────────────────────────────────────── -->

    <!-- Botón relay (flujo legacy, oculto si no se necesita) -->
    <LinearLayout
        android:id="@+id/layoutRelayConnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toTopOf="@id/btnHangUp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRelay"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_relay"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:singleLine="true"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- tilRoom: oculto pero necesario para el binding -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRoom"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_room"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_connect"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="24dp" />

    </LinearLayout>

    <!-- ── Botón Colgar ───────────────────────────────────────────────────────── -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHangUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_hang_up"
        android:visibility="gone"
        style="@style/Widget.Material3.Button.TonalButton"
        app:icon="@android:drawable/ic_media_pause"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
